VITE_MICROSOFT_CLIENT_ID=your-azure-app-client-id
VITE_REDIRECT_URI=https://feathermail.app/auth/callback
VITE_MICROSOFT_TENANT_ID=common

# Backend (do not commit secrets)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
REDIRECT_URI=https://feathermail.app/auth/callback

# Summary generation mode: "real" calls the deployed model, "dummy" returns local test payloads.
SUMMARY_MODE=real
BITNET_SERVER_URL=http://your-azure-url
SUMMARY_MODEL_TIMEOUT_SECONDS=180

flowchart TD
  A[Open inbox view] --> B[Fetch first page from Supabase\nlimit = 15]
  B --> C[Render list in about 200ms]

  C --> D{User scrolls down?}
  D -- No --> D
  D -- Yes --> E[Sentinel enters viewport]

  E --> F[loadMore runs]
  F --> G[Use oldest loaded email timestamp\nas cursor]
  G --> H[Fetch next 15 older emails]

  H --> I{Rows returned > 0?}
  I -- Yes --> J[Append rows to bottom of list]
  J --> D

  I -- No --> K[Set hasMore = false]
  K --> L[Observer stops firing\nno more pagination requests]

  M[Realtime INSERT from Pub/Sub\nvia Supabase channel] --> N[Prepend new email to top]
  N --> C

  classDef start fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px,color:#1b5e20
  classDef action fill:#e3f2fd,stroke:#1565c0,stroke-width:1px,color:#0d47a1
  classDef decision fill:#fff8e1,stroke:#ef6c00,stroke-width:1px,color:#e65100
  classDef stop fill:#ffebee,stroke:#c62828,stroke-width:1px,color:#b71c1c

  class A,C start
  class B,E,F,G,H,J,N action
  class D,I decision
  class K,L stop


